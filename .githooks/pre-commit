#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

cd "$ROOT_DIR"

relevant_changes="$(git diff --cached --name-only -- cmd scripts/build-skills.sh package.json package-lock.json go.mod go.sum)"
[ -n "$relevant_changes" ] || exit 0

"$ROOT_DIR/scripts/build-skills.sh"

for cmd_dir in "$ROOT_DIR"/cmd/*; do
  [ -d "$cmd_dir" ] || continue
  name="$(basename "$cmd_dir")"
  git add -A -- ".agents/skills/$name/scripts/$name"
done
