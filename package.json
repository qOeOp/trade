{
  "name": "trade",
  "version": "1.0.0",
  "description": "这是一个给开发者自己长期使用、可被 Claude、Gemini、Codex 等 agent 直接调用的加密交易工作仓库。",
  "main": "index.js",
  "bin": {
    "binance-aggtrades-fetch": "dist/binance-aggtrades-fetch/cli.js",
    "binance-account-snapshot": "dist/binance-account-snapshot/cli.js",
    "binance-liquidation-zones": "dist/binance-liquidation-zones/cli",
    "binance-symbol-snapshot": "dist/binance-symbol-snapshot/cli.js",
    "binance-market-scan": "dist/binance-market-scan/cli.js",
    "binance-order-preview": "dist/binance-order-preview/cli.js",
    "binance-order-place": "dist/binance-order-place/cli.js",
    "binance-order-cancel": "dist/binance-order-cancel/cli.js",
    "binance-position-protect": "dist/binance-position-protect/cli.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "./scripts/build-skills.sh",
    "check:build": "./scripts/check-skills-build.sh",
    "setup-hooks": "./scripts/setup-git-hooks.sh",
    "prepare": "./scripts/setup-git-hooks.sh",
    "test": "node --import tsx --test cmd/**/*.test.ts && python3 -m unittest discover -s cmd/binance-liquidation-zones -p 'test_*.py'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qOeOp/trade.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/qOeOp/trade/issues"
  },
  "homepage": "https://github.com/qOeOp/trade#readme",
  "dependencies": {
    "binance-api-node": "^0.13.9"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vercel/ncc": "^0.38.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
